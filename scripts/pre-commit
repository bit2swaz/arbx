#!/bin/sh
# pre-commit hook for arbx
# Install via: sh scripts/install-hooks.sh
#
# Runs the same checks as CI so you never push a broken commit.
# All checks must pass before the commit is allowed.

set -e

echo "==> Running pre-commit checks..."

echo "  [1/3] cargo fmt --check"
cargo fmt --check

echo "  [2/3] cargo clippy -- -D warnings"
cargo clippy --workspace --all-targets --all-features -- -D warnings

echo "  [3/3] cargo test --workspace --quiet"
cargo test --workspace --quiet

echo "Pre-commit checks passed."
