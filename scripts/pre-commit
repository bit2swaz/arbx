#!/bin/sh
set -e

# Skip checks if workspace has no members yet
MEMBERS=$(cargo metadata --no-deps --format-version 1 2>/dev/null | python3 -c "import sys,json; d=json.load(sys.stdin); print(len(d['packages']))" 2>/dev/null || echo "0")

if [ "$MEMBERS" = "0" ]; then
  echo "Empty workspace — skipping pre-commit checks."
  exit 0
fi

echo "==> Running pre-commit checks..."
echo "  [1/3] cargo fmt --check"
cargo fmt --check
echo "  [2/3] cargo clippy"
cargo clippy -- -D warnings
echo "  [3/3] cargo test"
cargo test --workspace --quiet
echo "Pre-commit checks passed."
